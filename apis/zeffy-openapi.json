  },
  "info": {
    "title": "Zeffy API",
    "description": "Public API for accessing Zeffy data — payments, contacts, and campaigns.\n\n## Authentication\n\nAll requests require a Bearer token in the `Authorization` header.\n\nTo get your API key *(organization owner only)*:\n1. Go to **[Settings → Integrations](https://www.zeffy.com/o/settings?openIntegrations=true)** in your Zeffy dashboard\n2. Complete the quick setup to generate your key\n3. Use it as: `Authorization: Bearer YOUR_API_KEY`\n\n## Webhooks\n\nTo receive real-time payment notifications, configure a webhook URL in the same **[Integrations dialog](https://www.zeffy.com/o/settings?openIntegrations=true)**.\n\nYour endpoint will receive a `POST` request with a `payment.completed` event each time a payment is processed. Respond with any `2xx` status to acknowledge receipt — non-2xx responses trigger retries.",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [
    {
      "url": "https://api.zeffy.com"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "description": "Your organization API key"
      }
    },
    "schemas": {
      "Refund": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "rf1b2c3d4-e5f6-7890-abcd-ef1234567890"
          },
          "object": {
            "type": "string",
            "example": "refund",
            "enum": [
              "refund"
            ]
          },
          "amount": {
            "type": "number",
            "description": "Refunded amount in cents",
            "example": 2500
          },
          "currency": {
            "type": "string",
            "example": "cad"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "succeeded",
              "failed"
            ],
            "example": "succeeded",
            "description": "Refund status"
          },
          "created": {
            "type": "number",
            "description": "Unix timestamp",
            "example": 1700100000
          }
        },
        "required": [
          "id",
          "object",
          "amount",
          "currency",
          "status",
          "created"
        ]
      },
      "Dispute": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "dp1b2c3d4-e5f6-7890-abcd-ef1234567890"
          },
          "object": {
            "type": "string",
            "example": "dispute",
            "enum": [
              "dispute"
            ]
          },
          "amount": {
            "type": "number",
            "description": "Disputed amount in cents",
            "example": 5000
          },
          "currency": {
            "type": "string",
            "example": "cad"
          },
          "status": {
            "type": "string",
            "enum": [
              "needs_response",
              "won",
              "lost"
            ],
            "example": "needs_response",
            "description": "Dispute status"
          },
          "reason": {
            "type": "string",
            "example": "fraudulent",
            "description": "Reason for the dispute"
          },
          "created": {
            "type": "number",
            "description": "Unix timestamp",
            "example": 1700200000
          }
        },
        "required": [
          "id",
          "object",
          "amount",
          "currency",
          "status",
          "reason",
          "created"
        ]
      },
      "PaymentMethodDetail": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "example": "card",
            "description": "Payment method type"
          },
          "brand": {
            "type": "object",
            "nullable": true,
            "example": "visa",
            "description": "Card brand, if applicable"
          },
          "last4": {
            "type": "object",
            "nullable": true,
            "example": "4242",
            "description": "Last 4 digits of the card, if applicable"
          }
        },
        "required": [
          "type",
          "brand",
          "last4"
        ]
      },
      "Buyer": {
        "type": "object",
        "properties": {
          "email": {
            "type": "object",
            "nullable": true,
            "example": "jane@example.com"
          },
          "first_name": {
            "type": "object",
            "nullable": true,
            "example": "Jane"
          },
          "last_name": {
            "type": "object",
            "nullable": true,
            "example": "Doe"
          },
          "is_corporate": {
            "type": "boolean",
            "example": false,
            "description": "True when the buyer selected the 'I am donating as an organization' option on the form."
          },
          "company_name": {
            "type": "object",
            "nullable": true,
            "example": "Acme Corp",
            "description": "Company / organization name entered by the buyer when is_corporate is true. Null when the donation is from an individual."
          }
        },
        "required": [
          "email",
          "first_name",
          "last_name",
          "is_corporate",
          "company_name"
        ]
      },
      "Discount": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "SAVE10",
            "description": "Discount code entered by the buyer"
          },
          "amount": {
            "type": "number",
            "description": "Amount discounted in cents",
            "example": 1000
          }
        },
        "required": [
          "code",
          "amount"
        ]
      },
      "QuestionAnswer": {
        "type": "object",
        "properties": {
          "question": {
            "type": "string",
            "example": "How did you hear about us?"
          },
          "type": {
            "type": "string",
            "example": "text",
            "enum": [
              "text",
              "single_select",
              "multi_select",
              "checkbox",
              "date",
              "email",
              "phone",
              "name"
            ]
          },
          "answer": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              {
                "type": "boolean"
              }
            ],
            "example": "A friend told me",
            "description": "String for text/single_select/date/email/phone/name. Array of strings for multi_select. Boolean for checkbox."
          }
        },
        "required": [
          "question",
          "type",
          "answer"
        ]
      },
      "Tribute": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "in_honour_of",
              "in_memory_of"
            ],
            "example": "in_memory_of",
            "description": "Whether the donor made the donation in honour of someone (alive) or in memory of someone (deceased)"
          },
          "honouree_name": {
            "type": "object",
            "nullable": true,
            "example": "Jane Smith",
            "description": "Name of the person being honoured or memorialised, as entered by the donor. Null when the donor left it blank."
          }
        },
        "required": [
          "type",
          "honouree_name"
        ]
      },
      "Item": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
          },
          "object": {
            "type": "string",
            "example": "item",
            "enum": [
              "item"
            ]
          },
          "type": {
            "type": "string",
            "enum": [
              "donation",
              "ticket",
              "additional_donation"
            ],
            "example": "donation"
          },
          "amount": {
            "type": "number",
            "description": "Amount in cents",
            "example": 5000
          },
          "currency": {
            "type": "string",
            "example": "cad"
          },
          "recurrence_interval": {
            "type": "object",
            "nullable": true,
            "example": "monthly",
            "description": "Recurrence interval if recurring, null otherwise"
          },
          "rate_id": {
            "type": "object",
            "nullable": true,
            "example": "r1b2c3d4-e5f6-7890-abcd-ef1234567890"
          },
          "contact_id": {
            "type": "object",
            "nullable": true,
            "example": "1a2b3c4d-5e6f-7a8b-9c0d-1e2f3a4b5c6d",
            "description": "Contact ID of the attendee (tickets only)"
          },
          "questions": {
            "description": "Per-ticket custom questions and answers (tickets only)",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QuestionAnswer"
            }
          },
          "tribute": {
            "nullable": true,
            "description": "Tribute (in honour of / in memory of) details for donation items. Null for non-donation items, and null when the donor did not select a tribute.",
            "allOf": [
              {
                "$ref": "#/components/schemas/Tribute"
              }
            ]
          }
        },
        "required": [
          "id",
          "object",
          "type",
          "amount",
          "currency",
          "recurrence_interval",
          "rate_id",
          "contact_id",
          "questions",
          "tribute"
        ]
      },
      "Recurring": {
        "type": "object",
        "properties": {
          "is_recurring": {
            "type": "boolean",
            "example": true
          },
          "status": {
            "type": "string",
            "example": "active"
          },
          "interval": {
            "type": "object",
            "nullable": true,
            "example": "monthly"
          },
          "subscription_id": {
            "type": "object",
            "nullable": true,
            "example": "s1b2c3d4-e5f6-7890-abcd-ef1234567890"
          },
          "current_period_start": {
            "type": "object",
            "nullable": true,
            "description": "Unix timestamp",
            "example": 1700000000
          },
          "current_period_end": {
            "type": "object",
            "nullable": true,
            "description": "Unix timestamp",
            "example": 1702592000
          }
        },
        "required": [
          "is_recurring",
          "status",
          "interval",
          "subscription_id",
          "current_period_start",
          "current_period_end"
        ]
      },
      "Payment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "p1b2c3d4-e5f6-7890-abcd-ef1234567890"
          },
          "object": {
            "type": "string",
            "example": "payment",
            "enum": [
              "payment"
