{
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/payments": {
      "get": {
        "description": "Returns a paginated list of payments for the authenticated organization.",
        "operationId": "PublicApiV1Controller_listPayments",
        "parameters": [
          {
            "name": "currency",
            "required": false,
            "in": "query",
            "description": "Filter by currency",
            "schema": {
              "enum": [
                "cad",
                "usd"
              ],
              "type": "string"
            }
          },
          {
            "name": "contact",
            "required": false,
            "in": "query",
            "description": "Filter by contact ID (UUID)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "campaign",
            "required": false,
            "in": "query",
            "description": "Filter by campaign ID (UUID)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "required": false,
            "in": "query",
            "description": "Filter by payment type",
            "schema": {
              "enum": [
                "online",
                "manual",
                "imported"
              ],
              "type": "string"
            }
          },
          {
            "name": "status",
            "required": false,
            "in": "query",
            "description": "Filter by payment status",
            "schema": {
              "enum": [
                "succeeded",
                "failed",
                "pending"
              ],
              "type": "string"
            }
          },
          {
            "name": "created[lte]",
            "required": false,
            "in": "query",
            "description": "Filter: created at or before (unix timestamp)",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "created[lt]",
            "required": false,
            "in": "query",
            "description": "Filter: created before (unix timestamp)",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "created[gte]",
            "required": false,
            "in": "query",
            "description": "Filter: created at or after (unix timestamp)",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "created[gt]",
            "required": false,
            "in": "query",
            "description": "Filter: created after (unix timestamp)",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "ending_before",
            "required": false,
            "in": "query",
            "description": "Cursor: payment ID to end before",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "starting_after",
            "required": false,
            "in": "query",
            "description": "Cursor: payment ID to start after",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "description": "Number of results (1-100, default 10)",
            "schema": {
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of payments",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentList"
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "List payments",
        "tags": [
          "Payments"
        ]
      }
    },
    "/api/v1/payments/{id}": {
      "get": {
        "description": "Returns a single payment with line items and subscription details.",
        "operationId": "PublicApiV1Controller_getPayment",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "Payment ID (UUID)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Payment object",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Payment"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "404": {
            "description": "Payment not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Get a payment",
        "tags": [
          "Payments"
        ]
      }
    },
